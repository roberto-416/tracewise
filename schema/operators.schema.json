{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "operators",
  "type": "array",
  "items": {
    "type": "object",
    "required": ["id", "name_en", "colour", "fare_group"],
    "additionalProperties": true,
    "properties": {
      "id": { "type": "string" },
      "name_en": { "type": "string" },
      "name_ja": { "type": "string" },
      "colour": { "type": "string", "pattern": "^#[0-9A-Fa-f]{6}$" },
      "fare_group": { "type": "string" },
      "url": { "type": "string", "format": "uri" }
    }
  }
}
